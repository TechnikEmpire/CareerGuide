# CareerGuide local data artifacts
data/processed/*.db
data/processed/*.sqlite
data/processed/*.sqlite3

# CareerGuide raw and generated corpus artifacts
# Policy:
# - raw vendor ESCO downloads stay ignored
# - normalized ESCO concept/relation artifacts, bilingual translated ESCO corpus,
#   and preprocessing manifests are tracked deliverables
data/raw/ESCO/
data/processed/esco/**/*.json
data/processed/esco/**/*.jsonl
!data/processed/esco/normalized/esco_concepts.en.jsonl
!data/processed/esco/normalized/esco_relations.jsonl
!data/processed/esco/manifests/*.json
!data/processed/esco/bilingual/esco_concepts.en_ru.jsonl

# Local model runtime artifacts and generated runtime config
models/*
!models/README.md
!models/README.en.md
!models/README.ru.md
config/*.local.json

# Persist the canonical FAISS retrieval cache for the active Qwen3 retrieval
# configuration. The local SQLite database remains untracked.
data/processed/retrieval/*
!data/processed/retrieval/README.md
!data/processed/retrieval/README.en.md
!data/processed/retrieval/README.ru.md
!data/processed/retrieval/faiss_hnsw.index
!data/processed/retrieval/faiss_hnsw_manifest.json

# Generated benchmark and evaluation outputs
eval/out/*
!eval/out/README.md
!eval/out/README.en.md
!eval/out/README.ru.md
!eval/out/dense_retrieval_tuning.json
!eval/out/answer_predictions.json
!eval/out/answer_scores.json
!eval/out/retrieval_predictions_dense.json
!eval/out/retrieval_predictions_rerank.json
!eval/out/retrieval_scores_dense.json
!eval/out/retrieval_scores_rerank.json
/.ssh
/Artifacts
